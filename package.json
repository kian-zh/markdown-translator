{
  "name": "markdown-translator",
  "displayName": "Markdown Translator",
  "description": "Read Markdown translations in Cursor without translating code.",
  "version": "0.1.0",
  "publisher": "kian-zh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kian-zh/markdown-translator"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "translate",
    "google translate",
    "cursor"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownTranslator",
          "title": "Markdown Translator",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "markdownTranslator": [
        {
          "id": "markdownTranslator.reader",
          "name": "Translated Reader"
        }
      ]
    },
    "commands": [
      {
        "command": "markdownTranslator.refresh",
        "title": "Markdown Translator: Refresh Translation"
      },
      {
        "command": "markdownTranslator.open",
        "title": "Markdown Translator: Open Reader"
      }
    ],
    "configuration": {
      "title": "Markdown Translator",
      "properties": {
        "markdownTranslator.targetLanguage": {
          "type": "string",
          "default": "zh-CN",
          "description": "Language used for Markdown translations."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "check": "tsc --noEmit",
    "test": "npm run check && tsx --test test/*.test.ts",
    "package": "npm run check && npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "google-translate-token-with-mirror": "^1.3.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
